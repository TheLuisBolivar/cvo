# Rename this file to .env, or run `cvo setup` to fill it in interactively.
# This file is gitignored and never committed.

# Active provider used by `cvo run` (claude | openai | gemini | deepseek).
CVO_PROVIDER=claude

# API keys — only the one for the active provider is required.
# Run `cvo setup` to configure this interactively.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Get keys at:
#   Claude:    https://console.anthropic.com/settings/keys
#   ChatGPT:   https://platform.openai.com/api-keys
#   Gemini:    https://aistudio.google.com/apikey
#   DeepSeek:  https://platform.deepseek.com/api_keys
